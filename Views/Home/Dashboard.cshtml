@model BudgetTracker.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<!-- ===== Total Spending Card ===== -->
<div class="card mb-4" style="max-width: 300px;">
    <div class="card-body">
        <h5 class="card-title">Total Spending</h5>
        <!-- Display the grand total formatted as currency -->
        <p class="card-text fs-3">@Model.TotalSpending.ToString("C")</p>
    </div>
</div>

<!-- ===== Spending by Category Table ===== -->
<h2>Spending by Category</h2>

@if (Model.SpendingByCategory.Count == 0)
{
    <p>No transactions recorded yet.</p>
}
else
{
    <table class="table table-striped mb-4" style="max-width: 500px;">
        <thead>
            <tr>
                <th>Category</th>
                <th>Amount Spent</th>
            </tr>
        </thead>
        <tbody>
            <!-- Loop through each category and its total -->
            @foreach (var entry in Model.SpendingByCategory)
            {
                <tr>
                    <td>@entry.Key</td>
                    <td>@entry.Value.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- ===== Budget Progress Table ===== -->
<h2>Budget Progress</h2>

@if (Model.BudgetSummaries.Count == 0)
{
    <p>No budgets set up yet.</p>
}
else
{
    <table class="table table-bordered" style="max-width: 700px;">
        <thead class="table-dark">
            <tr>
                <th>Budget</th>
                <th>Budget Amount</th>
                <th>Spent</th>
                <th>Remaining</th>
                <th>Progress</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var summary in Model.BudgetSummaries)
            {
                <!-- Calculate how much is left and what percentage has been used -->
                decimal remaining = summary.BudgetAmount - summary.SpentAmount;
                decimal percentUsed = summary.BudgetAmount > 0
                    ? (summary.SpentAmount / summary.BudgetAmount) * 100
                    : 0;

                <!-- Cap the progress bar at 100% so it doesn't overflow visually -->
                int barWidth = (int)Math.Min(percentUsed, 100);

                <!-- Turn the bar red if over budget, yellow if close (>= 80%), green otherwise -->
                string barColor = percentUsed >= 100 ? "bg-danger"
                                : percentUsed >= 80  ? "bg-warning"
                                                     : "bg-success";
                <tr>
                    <td>@summary.Name</td>
                    <td>@summary.BudgetAmount.ToString("C")</td>
                    <td>@summary.SpentAmount.ToString("C")</td>
                    <!-- Show remaining in red if over budget -->
                    <td class="@(remaining < 0 ? "text-danger fw-bold" : "")">
                        @remaining.ToString("C")
                    </td>
                    <td style="min-width: 150px;">
                        <!-- Bootstrap progress bar -->
                        <div class="progress">
                            <div class="progress-bar @barColor"
                                 role="progressbar"
                                 style="width: @barWidth%"
                                 aria-valuenow="@barWidth"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                @((int)percentUsed)%
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
