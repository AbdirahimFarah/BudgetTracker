@{
    ViewData["Title"] = "Home";
}

<!-- Hero section: full-width dark banner with a call-to-action -->
<div class="py-5 text-white text-center" style="background-color: #1a1f2e;">
    <div class="container py-3">
        <h1 class="display-4 fw-bold mb-3">Take Control of Your Finances</h1>
        <p class="lead mb-4">Track spending, set budgets and hit your financial goals — all in one place.</p>
        <!-- Green Get Started button links straight to the Transactions list -->
        <a href="/Transactions" class="btn btn-lg px-4 fw-semibold"
           style="background-color: #2d8a4e; color: white;">Get Started</a>
    </div>
</div>

<!-- Feature cards: three equal columns showing what the app can do -->
<div class="container my-5">
    <div class="row g-4">

        <!-- Card 1: Track Transactions -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm p-3">
                <div class="card-body">
                    <!-- Credit card icon from Bootstrap Icons -->
                    <i class="bi bi-credit-card fs-1 text-success mb-3 d-block"></i>
                    <h5 class="card-title fw-semibold">Track Transactions</h5>
                    <p class="card-text text-muted">
                        Log every purchase and income in one place so you always know where your money is going.
                    </p>
                </div>
            </div>
        </div>

        <!-- Card 2: Set Budgets -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm p-3">
                <div class="card-body">
                    <!-- Pie chart icon from Bootstrap Icons -->
                    <i class="bi bi-pie-chart fs-1 text-success mb-3 d-block"></i>
                    <h5 class="card-title fw-semibold">Set Budgets</h5>
                    <p class="card-text text-muted">
                        Create monthly budgets for each spending category and stay on top of your limits.
                    </p>
                </div>
            </div>
        </div>

        <!-- Card 3: View Dashboard -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm p-3">
                <div class="card-body">
                    <!-- Bar chart icon from Bootstrap Icons -->
                    <i class="bi bi-bar-chart-line fs-1 text-success mb-3 d-block"></i>
                    <h5 class="card-title fw-semibold">View Dashboard</h5>
                    <p class="card-text text-muted">
                        Get a bird's-eye view of your spending habits and budget progress at a glance.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>
