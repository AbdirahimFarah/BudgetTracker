@model List<BudgetTracker.Models.Budget>

@{
    ViewData["Title"] = "Budgets";
}

<div class="container py-3">
    <!-- Heading and Add button sit side-by-side with space between them -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">All Budgets</h2>
        <!-- Green Add Budget button with a plus icon -->
        <a asp-action="Create" class="btn fw-semibold" style="background-color: #2d8a4e; color: white;">
            <i class="bi bi-plus-circle me-1"></i> Add Budget
        </a>
    </div>

    <!-- Show a message if there are no budgets yet -->
    @if (Model.Count == 0)
    {
        <p class="text-muted">No budgets yet. Add one above!</p>
    }
    else
    {
        <!-- table-hover highlights a row on mouseover; table-striped alternates row colours -->
        <table class="table table-hover table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Amount</th>
                    <th>Category</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Loop through each budget and display it as a table row -->
                @foreach (var budget in Model)
                {
                    <tr>
                        <td>@budget.Id</td>
                        <td>@budget.Name</td>
                        <td>£@budget.Amount.ToString("N2")</td>
                        <!-- Show the category name, or a dash if no category was selected -->
                        <td>@(budget.CategoryName ?? "-")</td>
                        <td>@budget.StartDate.ToShortDateString()</td>
                        <td>@budget.EndDate.ToShortDateString()</td>
                        <td>
                            <!-- Edit button links to the Edit page for this budget -->
                            <a asp-action="Edit" asp-route-id="@budget.Id"
                               class="btn btn-warning btn-sm me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <!-- Delete button submits a POST form; confirm() asks the user before deleting -->
                            <form asp-action="Delete" asp-route-id="@budget.Id"
                                  method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Are you sure you want to delete this?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
