@model BudgetTracker.Models.Budget

@{
    ViewData["Title"] = "Add Budget";
}

<h2>Add Budget</h2>

<!-- asp-action posts the form to the Create POST action -->
<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Budget Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Monthly Groceries" />
        <!-- Shows validation error message if Name is missing or too long -->
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Amount ($)</label>
        <input asp-for="Amount" class="form-control" placeholder="e.g. 500.00" />
        <!-- Shows validation error message if Amount is invalid -->
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <!-- Dropdown built from the categories list passed via ViewBag -->
        <select asp-for="CategoryId" class="form-select">
            <option value="">-- Select a Category --</option>
            @foreach (var category in ViewBag.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <!-- Shows validation error message if StartDate is missing -->
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <!-- Shows validation error message if EndDate is missing -->
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save Budget</button>
    <!-- Go back to the list without saving -->
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>

</form>

@section Scripts {
    <!-- Enables client-side validation (shows errors without a page reload) -->
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
