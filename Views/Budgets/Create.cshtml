@model BudgetTracker.Models.Budget

@{
    ViewData["Title"] = "Add Budget";
}

<!-- Centred card container; max-width keeps the form from stretching too wide on large screens -->
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12" style="max-width: 600px;">
            <div class="card shadow p-4">
                <div class="card-body">
                    <h2 class="mb-4">Add Budget</h2>

                    <!-- asp-action posts the form to the Create POST action -->
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Budget Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Monthly Groceries" />
                            <!-- Shows a validation error if Name is missing or too long -->
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <!-- Label uses £ instead of $ -->
                            <label asp-for="Amount" class="form-label">Amount (£)</label>
                            <input asp-for="Amount" class="form-control" placeholder="e.g. £500.00" />
                            <!-- Shows a validation error if Amount is invalid -->
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Category</label>
                            <!-- Dropdown built from the categories list passed via ViewBag -->
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">-- Select a Category --</option>
                                @foreach (var category in ViewBag.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <!-- Shows a validation error if StartDate is missing -->
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <!-- Shows a validation error if EndDate is missing -->
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>

                        <!-- Green Save button with a tick icon; grey Cancel button with an X icon -->
                        <button type="submit" class="btn fw-semibold"
                                style="background-color: #2d8a4e; color: white;">
                            <i class="bi bi-check-circle me-1"></i> Save Budget
                        </button>
                        <a asp-action="Index" class="btn btn-secondary ms-2">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </a>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Enables client-side validation (shows errors without a page reload) -->
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
