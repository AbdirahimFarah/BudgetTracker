@model List<BudgetTracker.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<h2>All Categories</h2>

<!-- Link to go to the Create form -->
<p>
    <a asp-action="Create" class="btn btn-primary">+ Add Category</a>
</p>

<!-- Show a message if the list is empty -->
@if (Model.Count == 0)
{
    <p>No categories yet. Add one above!</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            <!-- Loop through each category and display it as a table row -->
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                </tr>
            }
        </tbody>
    </table>
}
